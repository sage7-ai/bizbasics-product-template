# PRODUCT_NAME local dev environment
# Copy to .env and fill in values.

# Database
DATABASE_URL=postgres://bizbasics:bizbasics@localhost:5432/bizbasics_dev

# Redis
REDIS_URL=redis://localhost:6379/9

# Your product's OWN session-signing secret. Generate a random value (>=32
# bytes), unique to your product. This is NOT the platform's secret — never
# reuse the platform JWT secret here.
APP_SESSION_SECRET=generate-your-own-random-secret-min-32-chars

# Per-product platform credential for the SSO handoff (verify-app-token).
# Issued to you when you register your product (see https://bizbasics.io/docs).
PLATFORM_INTERNAL_KEY=your-product-sso-credential

# Platform service URLs (for local dev using platform docker compose)
AUTH_SERVICE_URL=http://localhost:8091
PLATFORM_API_URL=http://localhost:8092

# App-specific env vars
# MY_API_KEY=
